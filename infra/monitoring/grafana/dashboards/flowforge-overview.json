{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(flowforge_http_requests_total[5m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "HTTP Error Rate (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(flowforge_http_requests_total{status=~\"4..|5..\"}[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "HTTP Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flowforge_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(flowforge_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(flowforge_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Run Counts",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "flowforge_runs_started_total", "legendFormat": "Started" },
        { "expr": "flowforge_runs_completed_total", "legendFormat": "Completed" },
        { "expr": "flowforge_runs_failed_total", "legendFormat": "Failed" }
      ]
    },
    {
      "title": "Run Rate (started/completed/failed)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 16 },
      "targets": [
        { "expr": "rate(flowforge_runs_started_total[5m])", "legendFormat": "started/s" },
        { "expr": "rate(flowforge_runs_completed_total[5m])", "legendFormat": "completed/s" },
        { "expr": "rate(flowforge_runs_failed_total[5m])", "legendFormat": "failed/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Infrastructure Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "targets": [
        { "expr": "flowforge_pg_up", "legendFormat": "PostgreSQL" },
        { "expr": "flowforge_redis_up", "legendFormat": "Redis" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["flowforge"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "FlowForge Overview",
  "uid": "flowforge-overview"
}
